# Polymarket Whale Tracker Config

# Telegram Bot (for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHANNEL_ID=@your_channel

# Minimum position size ($) to alert on
MIN_ALERT_SIZE=5000

# Minimum ROI (%) to consider "whale alert"
MIN_ALERT_ROI=100

# Poll interval in minutes
POLL_INTERVAL_SECONDS=10

# API server port
PORT=3001

# --- Paper trading (copy top-trader signals into a virtual portfolio) ---
PAPER_TRADING_ENABLED=false
PAPER_INITIAL_BALANCE=100000
PAPER_MAX_POSITION_PCT=10
PAPER_MAX_DAILY_LOSS_PCT=5
PAPER_MAX_OPEN_POSITIONS=20
PAPER_MIN_WHALE_ROI=50

# --- AI risk agent (OpenAI) - approves/rejects or reduces size before paper trades ---
AI_RISK_AGENT_ENABLED=false
OPENAI_API_KEY=
OPENAI_RISK_MODEL=gpt-4o-mini
